{
  "name": "@unlocksaas/seo",
  "version": "0.1.1",
  "description": "Honesty-first JSON-LD, llms.txt, and verification primitives for AI-discoverable websites. Extracted from unlocksaas.com.",
  "keywords": [
    "seo",
    "geo",
    "aeo",
    "aio",
    "llmo",
    "json-ld",
    "structured-data",
    "schema.org",
    "llms.txt",
    "ai-overviews",
    "perplexity",
    "claude",
    "chatgpt",
    "next.js",
    "metadata",
    "speakable",
    "hreflang",
    "indexnow"
  ],
  "homepage": "https://unlocksaas.com",
  "bugs": {
    "url": "https://github.com/kindrat86/unlocksaas/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kindrat86/unlocksaas.git",
    "directory": "packages/seo"
  },
  "license": "MIT",
  "author": {
    "name": "Maryan",
    "email": "maryan@unlocksaas.com",
    "url": "https://unlocksaas.com"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jsonld": {
      "types": "./dist/jsonld/index.d.ts",
      "import": "./dist/jsonld/index.js"
    },
    "./llms": {
      "types": "./dist/llms/index.d.ts",
      "import": "./dist/llms/index.js"
    },
    "./honesty": {
      "types": "./dist/honesty/index.d.ts",
      "import": "./dist/honesty/index.js"
    },
    "./verification": {
      "types": "./dist/verification/index.d.ts",
      "import": "./dist/verification/index.js"
    },
    "./freshness": {
      "types": "./dist/freshness/index.d.ts",
      "import": "./dist/freshness/index.js"
    },
    "./review": {
      "types": "./dist/review/index.d.ts",
      "import": "./dist/review/index.js"
    },
    "./next": {
      "types": "./dist/adapters/next.d.ts",
      "import": "./dist/adapters/next.js"
    }
  },
  "bin": {
    "unlocksaas-seo": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "node --test --experimental-strip-types tests/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "cli": "node dist/cli/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "next": ">=14"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.5.0"
  }
}
